# ── Server ────────────────────────────────────────
PORT=8080
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app

# ── Database (Supabase Postgres connection string) ──
# Get this from Supabase → Project Settings → Database → Connection string (URI, "Transaction" mode for pooling)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ── Google OAuth ──────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback

# ── Email (SMTP - e.g. Gmail app password, or Resend/SendGrid SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Supply Chain Risk Monitor <no-reply@yourdomain.com>"

# ── Cloudinary (file storage) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=

# ── News ─────────────────────────────────────────────
NEWSAPI_KEY=

# ── Rate limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
